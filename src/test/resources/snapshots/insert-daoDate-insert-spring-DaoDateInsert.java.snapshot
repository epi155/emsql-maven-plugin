            if (log.isDebugEnabled()) {
                SqlTrace.showQuery(Q_0001, () -> {
                    return new SqlArg[]{
                        new SqlArg("dateNull", "LocalDate", dateNull),
                        new SqlArg("dateNotNull", "LocalDate", dateNotNull)
