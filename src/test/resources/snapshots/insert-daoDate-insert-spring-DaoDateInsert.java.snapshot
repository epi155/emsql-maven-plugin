     * @throws SQLException SQL error
     */
    @Transactional
    public int insert(            final LocalDate dateNull,
            final LocalDate dateNotNull)
            throws SQLException {
        final Connection c = DataSourceUtils.getConnection(dataSource);
        if (log.isDebugEnabled()) {
            SqlTrace.showQuery(Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("dateNull", "LocalDate", dateNull),
