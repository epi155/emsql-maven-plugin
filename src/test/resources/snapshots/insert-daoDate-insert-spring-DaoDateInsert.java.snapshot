    private static final String Q_0001 = "INSERT INTO t_date ( date_null, date_not_null ) VALUES ( ?, ? )";
    /**
     * Template SqlInsert
     * <pre>
     * insert into t_date (date_null, date_not_null)
     * values (:dateNull, :dateNotNull)
