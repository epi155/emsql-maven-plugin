import javax.sql.DataSource;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.datasource.DataSourceUtils;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

@Repository
public class DaoIntSelectOptional {
    private static final org.slf4j.Logger log = org.slf4j.LoggerFactory.getLogger(DaoIntSelectOptional.class);
    private final DataSource dataSource;
    @Autowired
    public DaoIntSelectOptional(DataSource dataSource) {
        this.dataSource = dataSource;
    }

    private static final String Q_0001 = "SELECT int_null, int_not_null FROM t_int where id = ?";
    /**
     * Template SqlSelectOptional
     * <pre>
     * select int_null, int_not_null
     * into :intNull, :intNotNull
     * from t_int
     * where id = :id
     * </pre>
     *
     * @param id :id (parameter #1)
     * @param so output constructor
     * @throws SQLException SQL error
     */
    @Transactional(readOnly=true)
    public <O extends FindByIdRS> Optional<O> findById(            final int id,
            final Supplier<O> so)
            throws SQLException {
        final Connection c = DataSourceUtils.getConnection(dataSource);
        if (log.isDebugEnabled()) {
            SqlTrace.showQuery(Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("id", "int", id)
                };
            });
        }
        try (PreparedStatement ps = c.prepareStatement(Q_0001)) {
            int ki=0;
            ps.setInt(++ki, id);
            ps.setFetchSize(2);
            ps.setMaxRows(2);
            try (ResultSet rs = ps.executeQuery()) {
                if (rs.next()) {
                    O o = so.get();
                    Integer o1 = EmSQL.getInt(rs,1);
                    o.setIntNull(o1);
                    int o2 = rs.getInt(2);
                    o.setIntNotNull(o2);
                    if (log.isTraceEnabled()) {
                        SqlTrace.showResult(
                            new SqlArg("intNull", "Integer", o1),
                            new SqlArg("intNotNull", "int", o2)
                        );
                    }
                    if (rs.next()) {
                        throw new SqlNonUniqueResultException();
                    } else {
                        return Optional.of(o);
                    }
                } else {
                    log.debug("*** NoResult ***");
                    return Optional.empty();
                }
            }
        } catch (SQLException e) {
            SqlTrace.showCause(e, Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("id", "int", id)
                };
            });
            throw e;
        }
    }
    /**
     * Example of DTO class using interface (setter)
     *<pre>
     *{@literal @}Data
     * public class DtoFindById implements FindByIdRS {
     *     private Integer intNull;
     *     private int intNotNull;
     * }
     *</pre>
     */
    public interface FindByIdRS {
        void setIntNull(Integer s);
        void setIntNotNull(int s);
    }
