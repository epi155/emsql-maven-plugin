import org.springframework.jdbc.datasource.DataSourceUtils;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

@Repository
public class DaoBigintSelectList {
    private static final org.slf4j.Logger log = org.slf4j.LoggerFactory.getLogger(DaoBigintSelectList.class);
    private final DataSource dataSource;
    @Autowired
    public DaoBigintSelectList(DataSource dataSource) {
        this.dataSource = dataSource;
    }

    private static final String Q_0001 = "SELECT bigint_null, bigint_not_null FROM t_bigint where id > ?";
    /**
     * Template SqlSelectList
     * <pre>
     * select bigint_null, bigint_not_null
     * into :bigintNull, :bigintNotNull
     * from t_bigint
     * where id > :id
     * </pre>
     *
     * @param id :id (parameter #1)
     * @param so output constructor
     * @throws SQLException SQL error
     */
    @Transactional(readOnly=true)
    public <O extends FindAllRS> List<O> findAll(            final int id,
            final Supplier<O> so)
            throws SQLException {
        final Connection c = DataSourceUtils.getConnection(dataSource);
        if (log.isDebugEnabled()) {
            SqlTrace.showQuery(Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("id", "int", id)
                };
            });
        }
        try (PreparedStatement ps = c.prepareStatement(Q_0001)) {
            int ki=0;
            ps.setInt(++ki, id);
            try (ResultSet rs = ps.executeQuery()) {
                List<O> list = new ArrayList<>();
                while (rs.next()) {
                    O o = so.get();
                    Long o1 = EmSQL.getLong(rs,1);
                    o.setBigintNull(o1);
                    long o2 = rs.getLong(2);
                    o.setBigintNotNull(o2);
                    if (log.isTraceEnabled()) {
                        SqlTrace.showResult(
                            new SqlArg("bigintNull", "Long", o1),
                            new SqlArg("bigintNotNull", "long", o2)
                        );
                    }
                    list.add(o);
                }
                return list;
            }
        } catch (SQLException e) {
            SqlTrace.showCause(e, Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("id", "int", id)
                };
            });
            throw e;
        }
    }
    /**
     * Example of DTO class using interface (setter)
