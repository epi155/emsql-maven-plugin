import io.github.epi155.emsql.runtime.EmSQL;
import io.github.epi155.emsql.runtime.SqlArg;
import io.github.epi155.emsql.runtime.SqlTrace;
import java.sql.*;
import java.util.ArrayList;
import java.util.List;
import java.util.function.Supplier;

public class DaoIntSelectList {
    private static final org.slf4j.Logger log = org.slf4j.LoggerFactory.getLogger(DaoIntSelectList.class);
    private DaoIntSelectList() {}

    private static final String Q_0001 = "SELECT int_null, int_not_null FROM t_int where id > ?";
    /**
     * Template SqlSelectList
     * <pre>
     * select int_null, int_not_null
     * into :intNull, :intNotNull
     * from t_int
     * where id > :id
     * </pre>
     *
     * @param c connection
     * @param id :id (parameter #1)
     * @param so output constructor
     * @throws SQLException SQL error
     */
    public static <O extends FindAllRS> List<O> findAll(
            final Connection c,
            final int id,
            final Supplier<O> so)
            throws SQLException {
        if (log.isDebugEnabled()) {
            SqlTrace.showQuery(Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("id", "int", id)
                };
            });
        }
        try (PreparedStatement ps = c.prepareStatement(Q_0001)) {
            int ki=0;
            ps.setInt(++ki, id);
            try (ResultSet rs = ps.executeQuery()) {
                List<O> list = new ArrayList<>();
                while (rs.next()) {
                    O o = so.get();
                    Integer o1 = EmSQL.getInt(rs,1);
                    o.setIntNull(o1);
                    int o2 = rs.getInt(2);
                    o.setIntNotNull(o2);
                    if (log.isTraceEnabled()) {
                        SqlTrace.showResult(
                            new SqlArg("intNull", "Integer", o1),
                            new SqlArg("intNotNull", "int", o2)
                        );
                    }
                    list.add(o);
                }
                return list;
            }
        } catch (SQLException e) {
            SqlTrace.showCause(e, Q_0001, () -> {
                return new SqlArg[]{
                    new SqlArg("id", "int", id)
                };
            });
            throw e;
        }
    }
    /**
     * Example of DTO class using interface (setter)
     *<pre>
     *{@literal @}Data
     * public class DtoFindAll implements FindAllRS {
     *     private Integer intNull;
     *     private int intNotNull;
     * }
     *</pre>
     */
    public interface FindAllRS {
        void setIntNull(Integer s);
        void setIntNotNull(int s);
    }
}
