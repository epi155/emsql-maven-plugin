<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>test</groupId>
    <artifactId>test-abc</artifactId>
    <version>1.1-A4-SNAPSHOT</version>

    <build>
        <plugins>
            <plugin>
                <groupId>io.github.epi155</groupId>
                <artifactId>emsql-maven-plugin</artifactId>
                <version>1.1-A4-SNAPSHOT</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <configDirectory>${project.basedir}/src/test/resources</configDirectory>
                    <generateDirectory>${project.basedir}/target/generated-test-sources/sandbox</generateDirectory>
                    <debugCode>true</debugCode>
                    <provider>Spring</provider>
                    <modules>
                        <module>testUnit.yaml</module>
                    </modules>
                    <addCompileSourceRoot>false</addCompileSourceRoot>
                    <addTestCompileSourceRoot>false</addTestCompileSourceRoot>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
